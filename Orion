<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Simulador Trading PRO</title>

<style>
body {
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
    color: white;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}

.container {
    background: rgba(0,0,0,0.6);
    padding: 30px;
    border-radius: 15px;
    width: 350px;
    box-shadow: 0 0 25px rgba(0,0,0,0.5);
}

h2 {
    text-align: center;
    margin-bottom: 20px;
}

input {
    width: 100%;
    padding: 10px;
    margin: 8px 0;
    border-radius: 8px;
    border: none;
}

button {
    width: 100%;
    padding: 12px;
    background: #00c6ff;
    border: none;
    border-radius: 10px;
    color: black;
    font-weight: bold;
    cursor: pointer;
    margin-top: 10px;
}

button:hover {
    background: #00ffcc;
}

.resultado {
    margin-top: 20px;
    text-align: center;
    font-size: 18px;
}
</style>

</head>
<body>

<div class="container">
<h2>📊 Simulador de Pips</h2>

<input id="balance" placeholder="Balance ($)" value="1500">
<input id="lot" placeholder="Lote" value="0.30">

<button onclick="calcular()">Calcular</button>

<div class="resultado" id="resultado"></div>
</div>

<script>

let entradas = [0,300,700,1200,1800,2500,3300,4200,5200,7200,10200,
14200,19200,25200,32200,40200,49200,59200,69200,79200,89200,99200,109200,119200,129200];

function calcular(){
let balance = parseFloat(document.getElementById("balance").value);
let lot = parseFloat(document.getElementById("lot").value);

let pipValue = 0.0001 * (lot/0.01);
let maxPips = 0;

for(let drop=0; drop<=200000; drop+=100){
    let loss = 0;

    for(let i=0;i<entradas.length;i++){
        if(drop >= entradas[i]){
            loss += (drop - entradas[i]) * pipValue;
        }
    }

    let equity = balance - loss;

    if(equity <= 0){
        maxPips = drop;
        break;
    }
}

document.getElementById("resultado").innerHTML =
"🔥 Aguanta hasta:<br><b>" + maxPips.toLocaleString() + " pips</b>";
}

</script>

</body>
</html>
